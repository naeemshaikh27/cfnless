{
  "name": "cfnless",
  "version": "0.0.5",
  "description": "Drop-in replacement for the Serverless Framework CLI using AWS SDK directly (no CloudFormation)",
  "bin": {
    "cfnless": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/index.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --no-cache --testPathPattern=__tests__/unit",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules jest --no-cache --testPathPattern=__tests__/unit",
    "test:integration:run": "NODE_OPTIONS=--experimental-vm-modules jest --no-cache --testPathPattern=__tests__/integration --testTimeout=60000",
    "test:integration": "npm run docker:up && npm run test:integration:run; npm run docker:down",
    "docker:up": "docker compose -f __tests__/integration/docker-compose.yml up -d --wait",
    "docker:down": "docker compose -f __tests__/integration/docker-compose.yml down -v",
    "test:all": "npm run docker:up && NODE_OPTIONS=--experimental-vm-modules jest --no-cache --testTimeout=60000; npm run docker:down",
    "release": "./scripts/publish.sh",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/naeemshaikh27/cfnless.git"
  },
  "homepage": "https://github.com/naeemshaikh27/cfnless#readme",
  "bugs": {
    "url": "https://github.com/naeemshaikh27/cfnless/issues"
  },
  "author": "Naeem Shaikh",
  "keywords": [
    "serverless",
    "aws",
    "lambda",
    "deploy",
    "cloudformation-free",
    "aws-sdk"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@aws-sdk/client-cloudformation": "^3",
    "@aws-sdk/client-cloudwatch-logs": "^3",
    "@aws-sdk/client-lambda": "^3",
    "@aws-sdk/client-resource-groups-tagging-api": "^3",
    "@aws-sdk/client-s3": "^3",
    "archiver": "^7",
    "dotenv": "^16",
    "esbuild": "^0.25",
    "js-yaml": "^4"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "jest": "^29",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testRegex": ".*\\.test\\.ts$",
    "roots": [
      "__tests__"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    },
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ]
  }
}
